# ─── LLM Provider ────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic                     # anthropic | openai | gemini
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# Get a Gemini key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# ─── MCP Server ──────────────────────────────────────────────────────────────
# HOST=127.0.0.1 is the safe default for laptop dev. Use 0.0.0.0 inside Docker
# or when you need LAN reachability (and have auth enabled).
MCP_SERVER_URL=http://localhost:7000
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=7000

# ─── Agent API ───────────────────────────────────────────────────────────────
AGENT_API_HOST=127.0.0.1
AGENT_API_PORT=8080

# ─── OpenRMF ─────────────────────────────────────────────────────────────────
OPENRMF_API_URL=http://localhost:8000
OPENRMF_API_TOKEN=

# ─── Auth (JWT) ──────────────────────────────────────────────────────────────
# IMPORTANT: when USE_AUTH=true, JWT_SECRET MUST be set to a strong random value.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
USE_AUTH=false
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_AUDIENCE=nayantra
JWT_ISSUER=nayantra

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the Agent API.
# Leave default for local dev. NEVER use "*" in production.
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://127.0.0.1:3000","http://127.0.0.1:8080"]

# ─── Isaac Sim (optional) ────────────────────────────────────────────────────
ISAAC_SIM_ENABLED=false
ISAAC_SIM_URL=http://localhost:8211
ISAAC_SIM_SCENE_PATH=/Isaac/Environments/Simple_Warehouse/warehouse.usd

# ─── Zenoh bridge (optional, for multi-site WAN deployments) ─────────────────
ZENOH_ENABLED=false
ZENOH_ROUTER_URL=tcp/localhost:7447
ZENOH_MODE=peer

# ─── Misc ────────────────────────────────────────────────────────────────────
DEBUG_MODE=true
LOGGING_LEVEL=INFO
